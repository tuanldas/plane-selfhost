# =============================================================================
# Cấu hình cho 1 instance Plane (1 server = 1 Plane)
# -----------------------------------------------------------------------------
# Copy thành `config.env` rồi điền giá trị thật, sau đó chạy ./bootstrap.sh
# (Hoặc chạy ./setup.sh để tạo file này theo kiểu hỏi-đáp.)
# =============================================================================

# Domain truy cập Plane. DNS (A record) phải trỏ về IP của server này.
DOMAIN=plane.example.com

# Tên định danh instance — dùng làm tên router/service Traefik và tên project
# của docker compose. Chỉ a-z, 0-9, - . Mỗi instance phải khác nhau.
PLANE_INSTANCE=plane

# (Tuỳ chọn) Ghim phiên bản Plane. Để trống = lấy bản "latest".
PLANE_VERSION=

# =============================================================================
# CHẾ ĐỘ CHẠY
#   true  = chạy SAU Traefik external có sẵn (Traefik lo TLS, gắn labels).
#   false = chạy Plane MẶC ĐỊNH như bình thường — không Traefik, không thêm gì.
# =============================================================================
USE_TRAEFIK=true

# ----- Chỉ dùng khi USE_TRAEFIK=true -----------------------------------------
# Network DOCKER external mà Traefik đang dùng (xem: docker network ls)
TRAEFIK_NETWORK=traefik-public
# Có dùng TLS/Let's Encrypt không?
#   true  = HTTPS, Traefik xin cert qua CERT_RESOLVER (domain thật)
#   false = HTTP, KHÔNG TLS (hợp cho .localhost / test local)
TRAEFIK_TLS=true
# Entrypoint Traefik để route tới. TLS=true → entrypoint HTTPS (vd "websecure").
#   TLS=false → entrypoint HTTP (vd "web").
TRAEFIK_ENTRYPOINT=websecure
# certResolver đã khai báo trong Traefik (chỉ dùng khi TRAEFIK_TLS=true).
# LƯU Ý: phải khớp ĐÚNG tên resolver trong cấu hình Traefik của bạn (vd "le").
CERT_RESOLVER=letsencrypt

# =============================================================================
# BẬT/TẮT SERVICE HẠ TẦNG (gộp theo env khi build)
#   internal = chạy service ngay trong stack này
#   external = KHÔNG chạy, dùng dịch vụ ngoài (khai connection trong plane.env)
# =============================================================================
DB_MODE=internal        # plane-db (PostgreSQL)   | external → đặt DATABASE_URL
REDIS_MODE=internal     # plane-redis (Valkey)    | external → đặt REDIS_URL
MQ_MODE=internal        # plane-mq (RabbitMQ)     | external → đặt AMQP_URL
STORAGE_MODE=internal   # plane-minio (S3)        | external → đặt AWS_* + USE_MINIO=0
