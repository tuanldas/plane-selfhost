# =============================================================================
# plane.env — Biến môi trường runtime cho các container Plane.
# bootstrap.sh sẽ copy file này thành plane.env (nếu chưa có), tự sinh SECRET_KEY
# và vá WEB_URL/CORS theo config.env. Bạn có thể chỉnh tay rồi `make restart`.
#
# LƯU Ý: image tag mặc định dùng APP_RELEASE=stable. Nếu cần khớp đúng một phiên
# bản Plane cụ thể, hãy đối chiếu với plane.env chính thức của phiên bản đó.
# =============================================================================

# Phiên bản image Plane (tag trên Docker Hub): stable | preview | vX.Y.Z
APP_RELEASE=stable

# ---- URL & CORS (bootstrap.sh sẽ vá theo DOMAIN) ----------------------------
WEB_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost
DEBUG=0
GUNICORN_WORKERS=1

# ---- Bảo mật / proxy --------------------------------------------------------
SECRET_KEY=
APP_PROTOCOL=http
TRUSTED_PROXIES=0.0.0.0/0
# Caddy nội bộ: ":80" khi sau Traefik; đặt = DOMAIN nếu muốn Caddy tự xin Let's Encrypt
SITE_ADDRESS=:80
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443
FILE_SIZE_LIMIT=5242880

# ---- PostgreSQL -------------------------------------------------------------
# Khi DB_MODE=internal, các biến POSTGRES_* dùng cho service plane-db.
POSTGRES_USER=plane
POSTGRES_PASSWORD=plane
POSTGRES_DB=plane
POSTGRES_HOST=plane-db
POSTGRES_PORT=5432
# Khi DB_MODE=external: trỏ DATABASE_URL sang DB ngoài và bỏ POSTGRES_* nội bộ.
DATABASE_URL=postgresql://plane:plane@plane-db:5432/plane

# ---- Redis / Valkey ---------------------------------------------------------
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379/

# ---- RabbitMQ ---------------------------------------------------------------
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=plane
RABBITMQ_DEFAULT_PASS=plane
RABBITMQ_DEFAULT_VHOST=plane
AMQP_URL=amqp://plane:plane@plane-mq:5672/plane

# ---- MinIO / S3 -------------------------------------------------------------
# Khi STORAGE_MODE=internal dùng MinIO nội bộ; external thì trỏ AWS_* sang S3 ngoài.
USE_MINIO=1
AWS_REGION=
AWS_ACCESS_KEY_ID=access-key
AWS_SECRET_ACCESS_KEY=secret-key
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
# Caddyfile của proxy route /{$BUCKET_NAME}/* -> MinIO. PHẢI có, nếu rỗng sẽ nuốt cả "/".
BUCKET_NAME=uploads
# Tài khoản root cho service plane-minio nội bộ (nên trùng AWS_* ở trên)
MINIO_ROOT_USER=access-key
MINIO_ROOT_PASSWORD=secret-key

# ---- Live (cộng tác real-time) ----------------------------------------------
# live cần URL nội bộ tới api + secret chia sẻ với api (CLI tự sinh nếu để trống).
API_BASE_URL=http://api:8000
LIVE_SERVER_SECRET_KEY=

# ---- Đăng ký / đăng nhập ----------------------------------------------------
ENABLE_SIGNUP=1
ENABLE_EMAIL_PASSWORD=1
ENABLE_MAGIC_LINK_LOGIN=0
